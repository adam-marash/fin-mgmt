; Marash Family Finances - master ledger
;
; Validate: bean-check main.beancount
; Query:    bean-query main.beancount "SELECT ..."

include "accounts.beancount"
include "prices.beancount"
include "2019/*/entries.beancount"
include "2020/*/entries.beancount"
include "2021/*/entries.beancount"
include "2022/*/entries.beancount"
include "2023/*/entries.beancount"
include "2024/*/entries.beancount"
include "2025/*/entries.beancount"
include "2026/*/entries.beancount"
